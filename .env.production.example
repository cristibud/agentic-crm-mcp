# =====================================================================
# Production environment variables for Coolify.
# Copy these into the Coolify project's "Environment Variables" section.
# Do NOT commit real secrets to git.
# =====================================================================

# ---- Database (external / managed Postgres) ----
# Full Prisma connection string. Use the one from your managed Postgres resource.
DATABASE_URL=postgres://postgres:password@host:5432/postgres

# ---- API auth / LLM ----
# Shared secret between web <-> api <-> mcp (X-API-Key header).
API_KEY=change-me-api-key
# OpenAI-compatible key (OpenRouter, OpenAI, etc.) used for default LLM settings.
OPENAI_API_KEY=sk-...
LLM_MODEL=deepseek/deepseek-r1
LLM_BASE_URL=https://openrouter.ai/api/v1/

# ---- Public URLs baked into the web (browser) bundle at BUILD time ----
# These MUST be the public domains you assign to the api / mcp services in Coolify.
# After the first deploy, set the api/mcp domains, then put them here and redeploy
# the web service so the new values are compiled in.
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_MCP_URL=https://mcp.your-domain.com
